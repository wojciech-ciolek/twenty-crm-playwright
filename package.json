{
  "name": "twenty-crm-playwright",
  "version": "1.0.0",
  "description": "E2E test portfolio for Twenty CRM – demonstrating senior QA automation patterns",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:auth": "playwright test tests/auth/",
    "test:people": "playwright test tests/people/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "codegen": "playwright codegen http://localhost:3000",
    "report": "playwright show-report",
    "dashboard": "ts-node reporters/generate-dashboard.ts",
    "lint": "eslint \"**/*.ts\"",
    "lint:fix": "eslint \"**/*.ts\" --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "dotenv": "^17.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.1"
  }
}
