{
  "name": "twenty-crm-playwright",
  "version": "1.0.0",
  "description": "E2E test portfolio for Twenty CRM – demonstrating senior QA automation patterns",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:auth": "playwright test tests/auth/",
    "test:people": "playwright test tests/people/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "codegen": "playwright codegen http://localhost:3000",
    "report": "playwright show-report",
    "dashboard": "ts-node reporters/generate-dashboard.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "dotenv": "^17.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}